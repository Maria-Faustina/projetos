def Adicionar_Tarefas(tarefas):
 while True:
    opcao = input(" Deseja adicionar mais tarefas [sim/não]?")
    if opcao == 'sim':
      item = str(input(" Adicione sua tarefa: "))
      tarefas.append(item)
      tarefas = []
    elif opcao == 'nao':
        return tarefas
